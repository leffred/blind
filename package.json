{
  "name": "blind",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "server",
    "tv-app",
    "mobile-app",
    "shared"
  ],
  "scripts": {
    "start": "npm start --workspace=server",
    "build": "npm run build --workspace=server",
    "dev:server": "npm run dev --workspace=server",
    "dev:tv": "npm run dev --workspace=tv-app",
    "dev:mobile": "npm run dev --workspace=mobile-app",
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:tv\" \"npm run dev:mobile\""
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
